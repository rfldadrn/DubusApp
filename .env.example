# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/toko_jahit"
DIRECT_URL="postgresql://postgres:yourpassword@localhost:5432/toko_jahit"

# NextAuth v5
# Generate dengan: npx auth secret
# atau: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-min-32-chars"
AUTH_URL="http://localhost:3000"

# App Config
NEXT_PUBLIC_APP_NAME="Toko Jahit App"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Backup
BACKUP_DIR="backups"
BACKUP_KEEP_DAYS="14"
BACKUP_FILE_PREFIX="dubusapp_"
# Optional (khusus jika pg_dump tidak ada di PATH)
# PG_DUMP_PATH="C:/laragon/bin/postgresql/postgresql-16.4/bin/pg_dump.exe"

# Google Drive Backup (Service Account)
# Pilih salah satu metode credential:
# 1) GDRIVE_SERVICE_ACCOUNT_JSON (raw JSON satu baris)
# 2) GDRIVE_SERVICE_ACCOUNT_BASE64 (JSON yang di-base64)
# 3) GDRIVE_SERVICE_ACCOUNT_FILE (path ke file JSON)
GDRIVE_SERVICE_ACCOUNT_FILE="./secrets/gdrive-service-account.json"
# GDRIVE_SERVICE_ACCOUNT_JSON=""
# GDRIVE_SERVICE_ACCOUNT_BASE64=""

# Optional alternative: OAuth user credentials (recommended if not using Shared Drive)
GDRIVE_OAUTH_CLIENT_ID=""
GDRIVE_OAUTH_CLIENT_SECRET=""
GDRIVE_OAUTH_REFRESH_TOKEN=""
GDRIVE_OAUTH_REDIRECT_URI="http://localhost"
GDRIVE_OAUTH_CLIENT_FILE=""
GDRIVE_OAUTH_SCOPES="https://www.googleapis.com/auth/drive.file"

# Optional: folder tujuan di Google Drive
GDRIVE_FOLDER_ID=""
GDRIVE_FOLDER_NAME=""

# Jumlah file backup yang dipertahankan di Drive (0 = tanpa cleanup remote)
GDRIVE_KEEP_FILES="30"

# Vercel Cron trigger (Hobby: 1x/day)
CRON_SECRET="replace-with-random-long-secret"

# Endpoint backup runner yang benar-benar menjalankan pg_dump + upload GDrive
# Contoh: webhook dari VPS, GitHub Actions dispatch endpoint, atau service worker internal
BACKUP_WEBHOOK_URL=""
BACKUP_WEBHOOK_TOKEN=""
